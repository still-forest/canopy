{
  "name": "@still-forest/canopy",
  "version": "0.73.0",
  "author": "John Szymanowski",
  "license": "MIT",
  "description": "React components, built with Tailwind CSS, Shadcn, and VisX",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/styles/index.css",
    "./styles/*": "./dist/styles/*"
  },
  "files": [
    "dist"
  ],
  "private": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/still-forest/canopy.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -b && NODE_ENV=production vite build",
    "build:watch": "tsc -b && vite build --watch",
    "chromatic": "chromatic --exit-zero-on-changes",
    "dev": "vite",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:ci": "biome ci . && tsc --noEmit",
    "lint:fix": "biome check --write --unsafe .",
    "prepublishOnly": "pnpm build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 7006",
    "storybook:build": "storybook build",
    "storybook:build:docs": "storybook build --docs",
    "storybook:docs": "storybook dev --docs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "release": "release-it",
    "release:dry-run": "release-it --dry-run"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@daypicker/react": "10.0.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "lucide-react": "1.24.0",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@still-forest/biomejs-config": "2.2.0",
    "@storybook/addon-docs": "10.5.0",
    "@storybook/addon-themes": "10.5.0",
    "@storybook/builder-vite": "10.5.0",
    "@storybook/react-vite": "10.5.0",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/devtools-vite": "0.8.1",
    "@tanstack/react-router": "1.170.18",
    "@tanstack/router-plugin": "1.168.20",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/typescript6": "6.0.2",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "jsdom": "29.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "release-it": "20.2.1",
    "storybook": "10.5.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vite-plugin-dts": "5.0.3",
    "vite-plugin-lib-inject-css": "2.2.2",
    "vitest": "4.1.10"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.0.0"
  },
  "packageManager": "pnpm@11.11.0"
}
